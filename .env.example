# ===========================================
# VideoShift Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# -------------------------------------------
# Node.js Configuration
# -------------------------------------------
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# -------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------
DATABASE_URL=postgresql://videoshift:videoshift_password@localhost:5432/videoshift

# -------------------------------------------
# Redis
# -------------------------------------------
REDIS_URL=redis://localhost:6379

# -------------------------------------------
# Authentication
# -------------------------------------------
JWT_SECRET=your_super_secret_jwt_key_change_in_production
SESSION_SECRET=your_super_secret_session_key_change_in_production

# Google OAuth (optional but recommended)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# -------------------------------------------
# Stripe (for payments)
# -------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID_MONTHLY=price_monthly_subscription_id
STRIPE_PRICE_ID_YEARLY=price_yearly_subscription_id

# -------------------------------------------
# Storage Configuration
# -------------------------------------------
# Options: local, s3
STORAGE_PROVIDER=local

# Local storage paths
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# S3 Configuration (for production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=videoshift-uploads
S3_UPLOAD_DIR=uploads
S3_OUTPUT_DIR=outputs

# MinIO (for local S3-compatible storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_password

# -------------------------------------------
# File Limits
# -------------------------------------------
MAX_FILE_SIZE_FREE=524288000
MAX_FILE_SIZE_PREMIUM=4294967296
MAX_CONVERSIONS_FREE_DAILY=2

# -------------------------------------------
# Rate Limiting
# -------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# -------------------------------------------
# FFmpeg Configuration
# -------------------------------------------
FFMPEG_TIMEOUT=600000
FFMPEG_WATERMARK_TEXT="Converted with VideoShift (Free)"

# -------------------------------------------
# Email (for future features)
# -------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@videoshift.com
