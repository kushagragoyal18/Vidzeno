NODE_ENV=test
PORT=3002

# Use a separate test database
DATABASE_URL=postgresql://videoshift:videoshift_password@localhost:5432/videoshift_test

REDIS_URL=redis://localhost:6379

JWT_SECRET=test-jwt-secret-do-not-use-in-production
SESSION_SECRET=test-session-secret

# File limits
MAX_FILE_SIZE_FREE=524288000
MAX_FILE_SIZE_PREMIUM=4294967296
MAX_CONVERSIONS_FREE_DAILY=2

# Rate limiting (relaxed for tests)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# Storage
UPLOAD_DIR=./uploads-test
OUTPUT_DIR=./outputs-test

# FFmpeg
FFMPEG_TIMEOUT=30000
FFMPEG_WATERMARK_TEXT=VideoShift Test

# Stripe (test keys — no real charges)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_ID_MONTHLY=price_test_monthly
STRIPE_PRICE_ID_YEARLY=price_test_yearly

FRONTEND_URL=http://localhost:5173
